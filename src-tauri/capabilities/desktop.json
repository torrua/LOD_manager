{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-capability",
  "description": "Capability for desktop platforms",
  "windows": ["main"],
  "platforms": ["linux", "windows", "macOS"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:scope-appdata-recursive",
    "os:allow-platform",
    "os:allow-os-type",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
