{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "mobile-capability",
  "description": "Capability for mobile platforms",
  "windows": ["main"],
  "platforms": ["android", "iOS"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:scope-appdata-recursive",
    "os:allow-platform",
    "os:allow-os-type"
  ]
}
