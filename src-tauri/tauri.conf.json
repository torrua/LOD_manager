{
  "productName": "LOD Manager",
  "version": "1.6.5",
  "identifier": "com.lod.manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LOD Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 360,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/icon_128x128.png",
      "icons/icon_128x128@2x.png",
      "icons/icon_256x256.png",
      "icons/icon_512x512.png",
      "icons/Square44x44Logo.png"
    ],
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "16"
    }
  },
  "plugins": {
    "dialog": null,
    "fs": {},
    "os": null,
    "updater": {
      "pubkey": "RWTokZmjPABFWEwpRlcOKxI+IUThqQhDWDw6XpIizc7KYAGH0s33oUPe",
      "endpoints": ["https://github.com/torrua/LOD_manager/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
