{
  "name": "lod-manager",
  "version": "1.6.1",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "tauri dev",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "ci:check": "npm run format:check && npm run lint && npm run check && npm run rust:fmt:check && npm run rust:lint"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-os": "^2.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@typescript-eslint/types": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.45.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^0.43.0",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.1"
  }
}
